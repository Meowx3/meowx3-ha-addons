# Access Control
allow 10.0.0.0/8
allow 192.168.0.0/16

# GPSD as a reference clock (SHM)
# Refclock: Type SHM, Offset 0=NMEA, 1=PPS
refclock SHM 0 poll 3 precision 1e-1 delay 200 refid GPS
refclock SHM 1 poll 3 precision 1e-7 delay 0 refid PPS

# Stratum 1 - we are the master clock
local stratum 1

# Drift and stability
driftfile /var/lib/chrony/drift
maxupdateslock 0

# Logging for Web UI consumption
logdir /var/log/chrony
