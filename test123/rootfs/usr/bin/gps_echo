#!/bin/bash

# Echo GPS data from gpsd to the shell
# Uses u-blox 7 receiver with configurable device and baud rate

declare GPS_DEVICE BAUD_RATE

# Get configuration options
GPS_DEVICE=$(bashio::config 'gps_device')
BAUD_RATE=$(bashio::config 'baud_rate')

# Default values if not specified
GPS_DEVICE="${GPS_DEVICE:-/dev/ttyACM0}"
BAUD_RATE="${BAUD_RATE:-9600}"

bashio::log.info "Starting GPS data echo..."
bashio::log.info "GPS device: ${GPS_DEVICE}"
bashio::log.info "Baud rate: ${BAUD_RATE}"

# Configure the serial device with the specified baud rate
stty -F "${GPS_DEVICE}" ${BAUD_RATE} raw -echo

bashio::log.info "Reading GPS data from ${GPS_DEVICE}..."

# Read and echo GPS data continuously
while read -r line < "${GPS_DEVICE}"; do
    if [[ -n "$line" ]]; then
        echo "$line"
    fi
done
