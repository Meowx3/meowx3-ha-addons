#!/bin/sh -e

# Initialize gpsd service for u-blox 7 receiver
bashio::log.info "Initializing gpsd with u-blox 7 receiver..."

GPS_DEVICE=$(bashio::config 'gps_device')
BAUD_RATE=$(bashio::config 'baud_rate')

GPS_DEVICE="${GPS_DEVICE:-/dev/ttyACM0}"
BAUD_RATE="${BAUD_RATE:-9600}"

# Configure serial port settings
stty -F "${GPS_DEVICE}" ${BAUD_RATE} raw -echo

# Start gpsd with the specified device and baud rate
bashio::log.info "Starting gpsd for device: ${GPS_DEVICE} at ${BAUD_RATE} baud"
gpsd -N -F /run/gpsd.sock -b "${GPS_DEVICE}"

bashio::log.info "gpsd initialized successfully"
