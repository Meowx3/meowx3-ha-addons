# NTP Server Settings
driftfile /var/lib/chrony/drift
logdir /var/log/chrony

# Network Access (Requested ranges)
allow 10.0.0.0/8
allow 192.168.0.0/16

# GPSD NMEA Source (SHM - Shared Memory)
# Refclock 0 is usually the NMEA data from gpsd
refclock SHM 0 poll 3 delay 0.2 precision 1e-1

# PPS Source (Enabled via script if configured)
# {{PPS_CONFIG}}

# Local stratum 1 server
local stratum 1 font "GPS-NTP"
